names(Hitters)


set.seed(1)


library(glmnet)


x = model.matrix(Salary ~ ., Hitters)[,-1]


y = Hitters$Salary


grid = 10^seq(10, -2, length=100)


ridge.mod = glmnet(x, y, alpha=0, lmbda=grid)


dim(coef(ridge.mod))


ridge.mod$lambda[50]


ridge.mod$lambda[30]


plot(ridge.mod$lambda)


coef(ridge.mod)[,20]


predict(ridge.mod, s=50, typ="coefficients")[1:20,]


set.seed(1)
train = sample(1:nrow(x), nrow(x)/2)
test = (-train)
y.test = y[test]


ridge.mod = glmnet(x[train,], y[train], alpha=0,
                   lambda=grid, thresh=1e-12)


ridge.pred = predict(ridge.mod, s=4, newx=x[test,])


mean((ridge.pred - y.test)^2)


ridge.pred = predict(ridge.mod, s=0, newx=x[test,],
                     exact=T, x=x[train,], y=y[train])


mean((ridge.pred -y.test)^2)


lm01 = lm(y ~ x, subset=train)


summary(lm01)


ridge.pred = predict(ridge.mod, s=0, exact=T, 
    type="coefficients", x=x[train,], y=y[train])


summary(ridge.pred)


set.seed(1)


cv.out <- cv.glmnet(x[train, ], y[train], alpha = 0)


plot(cv.out)


bestlam <- cv.out$lambda.min


bestlam



